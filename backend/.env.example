# Copie para `.env` (e exporte as variáveis no seu shell, ou use um pacote
# como dotenv) caso queira rodar `npm start` FORA do Docker mas ainda assim
# customizar a configuração. Todos os valores abaixo são os defaults usados
# por backend/infra/config quando a variável correspondente não existe -
# ou seja, sem este arquivo o backend continua funcionando exatamente como
# antes da integração com Docker.
#
#   cp .env.example .env

# Porta HTTP do Express + Socket.io
PORT=5000

# String de conexão do MongoDB.
# Dentro do docker-compose, este valor é sobrescrito automaticamente para
# "mongodb://mongo:27017/getapetref" (o nome "mongo" é resolvido pela rede
# interna do Docker).
MONGO_URI=mongodb://localhost:27017/getapetref

# Origem permitida pelo CORS (Express + Socket.io)
CORS_ORIGIN=http://localhost:3000

# Segredo usado para assinar/verificar tokens JWT
JWT_SECRET=nossosecret

# development | production | test
NODE_ENV=development
